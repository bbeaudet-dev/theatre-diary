# Local (used by Expo at build time)
EXPO_PUBLIC_CONVEX_URL=https://your-project.convex.cloud
EXPO_PUBLIC_CONVEX_SITE_URL=https://your-project.convex.site

# Convex Dashboard environment variables:
# BETTER_AUTH_SECRET        — openssl rand -base64 32
# GOOGLE_CLIENT_ID          — Web client ID from Google Cloud Console
# GOOGLE_CLIENT_SECRET      — Web client secret from Google Cloud Console
# NATIVE_APP_URL            — theatrediary://
# APPLE_CLIENT_ID           — Services ID from Apple Developer (optional)
# APPLE_CLIENT_SECRET       — JWT from Apple Developer key (optional)
# APPLE_APP_BUNDLE_ID       — com.theatrediary.app (optional)
